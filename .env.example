# OmniTools MCP Server Configuration

# Tool Execution
TOOL_TIMEOUT=60                          # Timeout in seconds for tool execution
MAX_FILE_SIZE=52428800                    # Maximum file size in bytes (50 MB)

# Dispatcher Configuration
SEARCH_RESULT_LIMIT=10                    # Number of search results to return
SEARCH_RANKING_METHOD=keyword             # Ranking method: keyword | semantic (future)
OMNI_BACKEND=local                         # Backend mode: local | adapter
OMNI_ADAPTER_URL=http://127.0.0.1:8081    # Omni adapter base URL (adapter mode)
IT_TOOLS_URL=http://127.0.0.1:8082        # IT-Tools UI base URL (Docker topology)

# Security
ALLOWED_DIRECTORIES=/tmp,/home/user/workspace  # Comma-separated list of allowed directories

# Logging
LOG_LEVEL=info                            # Logging level: debug | info | warn | error
LOG_FILE=logs/mcp-server.log              # Path to log file

# FFmpeg (if not in PATH)
# FFMPEG_PATH=/usr/bin/ffmpeg

# Optional external toolset UIs
# OMNITOOLS_URL=http://localhost:8080
# IT_TOOLS_URL=http://localhost:8082
